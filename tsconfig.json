{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": [
      "miniprogram-api-typings"
    ],
    "baseUrl": "."
  },
  "include": [
    "miniprogram/**/*",
    "*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
