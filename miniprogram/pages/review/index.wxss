@import "../../styles/tokens.wxss";

.review-page {
  position: relative;
  padding: 24rpx 24rpx 44rpx;
  overflow: hidden;
}

.review-glow {
  position: absolute;
  top: -120rpx;
  right: -120rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(156, 183, 181, 0.18) 0%, rgba(156, 183, 181, 0) 72%);
  filter: blur(10rpx);
  animation: drift 10s ease-in-out infinite;
}

.review-hero,
.section-card,
.filter-chip {
  box-shadow: var(--shadow-card);
}

.review-hero {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 30rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, #fffdf8 0%, #f3efe8 100%);
}

.review-hero__label,
.section-tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--brand-soft);
  color: var(--brand);
  font-size: 22rpx;
}

.review-hero__title {
  margin-top: 16rpx;
  color: var(--ink-strong);
  font-size: 42rpx;
  font-weight: 700;
}

.review-hero__desc,
.queue-desc,
.section-desc {
  color: var(--ink-soft);
  font-size: 24rpx;
  line-height: 1.7;
}

.review-hero__desc {
  margin-top: 10rpx;
  max-width: 480rpx;
}

.review-hero__badge {
  align-self: flex-start;
  min-width: 102rpx;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: #f0f4ef;
  color: var(--brand-deep);
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}

.filter-row {
  display: flex;
  gap: 14rpx;
  margin: 20rpx 0;
  padding-bottom: 8rpx;
  overflow-x: auto;
}

.filter-chip {
  flex-shrink: 0;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 253, 248, 0.92);
  color: var(--ink-soft);
  font-size: 22rpx;
}

.filter-chip--active {
  background: #567f71;
  color: #fffdf8;
  animation: pulse-soft 2.2s ease-in-out infinite;
}

.section-card {
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 30rpx;
  background: var(--surface);
}

.section-head,
.queue-card,
.queue-top,
.weak-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.section-title,
.queue-title {
  color: var(--ink-strong);
  font-weight: 700;
}

.section-title {
  font-size: 30rpx;
}

.section-desc {
  margin-top: 8rpx;
}

.queue-card,
.weak-row {
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--line);
}

.queue-card:last-child,
.weak-row:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.queue-card__main {
  flex: 1;
  min-width: 0;
}

.queue-top {
  align-items: center;
}

.queue-title {
  font-size: 30rpx;
}

.queue-desc {
  margin-top: 8rpx;
}

.priority-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.priority-badge--urgent {
  background: rgba(201, 106, 87, 0.12);
  color: #a05c4d;
}

.priority-badge--focus {
  background: rgba(79, 122, 108, 0.10);
  color: var(--brand);
}

.priority-badge--warning {
  background: rgba(216, 171, 104, 0.16);
  color: #a2763d;
}

.priority-badge--normal {
  background: rgba(109, 123, 119, 0.12);
  color: #6d7b77;
}

.queue-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.queue-count {
  color: var(--ink-strong);
  font-size: 44rpx;
  font-weight: 700;
}

.queue-link {
  color: var(--brand);
  font-size: 22rpx;
  font-weight: 600;
}

.pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(201, 106, 87, 0.12);
  color: var(--danger);
  font-size: 22rpx;
}

.queue-desc--empty {
  padding-top: 22rpx;
}
