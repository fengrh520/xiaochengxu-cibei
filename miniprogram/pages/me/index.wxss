@import "../../styles/tokens.wxss";

.profile-page {
  position: relative;
  padding: 24rpx 24rpx 44rpx;
  overflow: hidden;
}

.profile-glow {
  position: absolute;
  top: -120rpx;
  left: -100rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(156, 183, 181, 0.18) 0%, rgba(156, 183, 181, 0) 72%);
  filter: blur(10rpx);
  animation: drift 10s ease-in-out infinite;
}

.profile-hero {
  position: relative;
  overflow: hidden;
  padding: 34rpx;
  border-radius: 36rpx;
  background:
    linear-gradient(160deg, rgba(255, 253, 248, 0.12) 0%, rgba(255, 253, 248, 0) 42%),
    linear-gradient(145deg, #2e413e 0%, #4e746b 56%, #739890 100%);
  color: #fffdf8;
  box-shadow: var(--shadow-hero);
}

.profile-hero::after {
  content: "";
  position: absolute;
  top: 0;
  right: -40rpx;
  width: 220rpx;
  height: 100%;
  background: linear-gradient(90deg, rgba(255, 253, 248, 0) 0%, rgba(255, 253, 248, 0.08) 48%, rgba(255, 253, 248, 0) 100%);
  transform: skewX(-18deg);
}

.profile-top,
.profile-stat-row,
.profile-link-row,
.section-head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.profile-top {
  position: relative;
  z-index: 1;
  align-items: center;
}

.profile-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: rgba(255, 253, 248, 0.16);
  border: 2rpx solid rgba(255, 253, 248, 0.20);
  font-size: 40rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.profile-meta {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.24;
}

.profile-book {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 253, 248, 0.82);
}

.profile-desc {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.72;
  color: rgba(255, 253, 248, 0.90);
}

.profile-divider {
  position: relative;
  z-index: 1;
  height: 1rpx;
  margin: 28rpx 0 22rpx;
  background: rgba(255, 253, 248, 0.18);
}

.profile-highlight {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.profile-highlight-badge {
  align-self: flex-start;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 253, 248, 0.14);
  font-size: 22rpx;
}

.profile-highlight-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 253, 248, 0.86);
}

.section-card {
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 30rpx;
  background: var(--surface);
  box-shadow: var(--shadow-card);
}

.section-title,
.profile-stat-label,
.profile-link-title {
  color: var(--ink-strong);
  font-weight: 700;
}

.section-title {
  font-size: 30rpx;
}

.section-desc {
  margin-top: 8rpx;
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1.6;
}

.profile-stat-row,
.profile-link-row {
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--line);
}

.profile-stat-row:last-child,
.profile-link-row:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.profile-stat-main,
.profile-link-main {
  flex: 1;
  min-width: 0;
}

.profile-stat-label,
.profile-link-title {
  font-size: 28rpx;
}

.profile-stat-note,
.profile-link-desc {
  margin-top: 8rpx;
  color: var(--ink-soft);
  font-size: 24rpx;
  line-height: 1.6;
}

.profile-stat-value {
  color: var(--brand);
  font-size: 40rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.profile-link-arrow {
  color: var(--brand);
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}
