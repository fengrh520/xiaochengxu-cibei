@import "../../styles/tokens.wxss";
.page { min-height: 100vh; padding: 24rpx 24rpx 40rpx; background: linear-gradient(180deg, #eef2ff 0%, #f4f7fb 280rpx, #f4f7fb 100%); }
.hero-card { padding: 32rpx; border-radius: 32rpx; background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 60%, #4f46e5 100%); color: #ffffff; box-shadow: var(--shadow-hero); }
.hero-card__header { display: flex; align-items: center; gap: 24rpx; }
.avatar { width: 112rpx; height: 112rpx; border-radius: 50%; background: rgba(255, 255, 255, 0.14); border: 2rpx solid rgba(255, 255, 255, 0.2); font-size: 40rpx; font-weight: 700; line-height: 112rpx; text-align: center; flex-shrink: 0; }
.hero-card__content { flex: 1; min-width: 0; }
.hero-card__name { font-size: 42rpx; font-weight: 700; line-height: 1.3; }
.hero-card__meta { margin-top: 10rpx; font-size: 24rpx; opacity: 0.82; }
.hero-card__bio { margin-top: 14rpx; font-size: 26rpx; line-height: 1.7; opacity: 0.94; }
.hero-card__footer { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; margin-top: 28rpx; padding-top: 24rpx; border-top: 1rpx solid rgba(255, 255, 255, 0.18); }
.hero-card__badge { padding: 10rpx 18rpx; border-radius: 999rpx; background: rgba(255, 255, 255, 0.14); font-size: 22rpx; }
.hero-card__hint { font-size: 24rpx; opacity: 0.86; }
.section { margin-top: 28rpx; padding: 28rpx 24rpx; border-radius: 28rpx; background: #ffffff; box-shadow: var(--shadow-card); }
.section__head { margin-bottom: 20rpx; }
.section__title { font-size: 32rpx; font-weight: 700; color: #111827; }
.section__subtitle { margin-top: 8rpx; font-size: 24rpx; line-height: 1.6; color: #6b7280; }
.stats-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18rpx; }
.stat-card { padding: 24rpx; border-radius: 22rpx; background: #f8fafc; }
.stat-card__value { font-size: 42rpx; font-weight: 700; color: #0f172a; }
.stat-card__label { margin-top: 10rpx; font-size: 24rpx; color: #334155; }
.stat-card__note { margin-top: 8rpx; font-size: 22rpx; line-height: 1.6; color: #94a3b8; }
.list { display: flex; flex-direction: column; gap: 16rpx; }
.list-item { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; padding: 24rpx; border-radius: 22rpx; background: #f8fafc; }
.list-item__main { flex: 1; min-width: 0; }
.list-item__title { font-size: 28rpx; font-weight: 700; color: #0f172a; }
.list-item__desc { margin-top: 8rpx; font-size: 24rpx; line-height: 1.6; color: #64748b; }
.list-item__extra { font-size: 22rpx; color: var(--brand); flex-shrink: 0; }
