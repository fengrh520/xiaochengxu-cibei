<view class="page profile-page">
  <view class="profile-hero">
    <view class="profile-top"><view class="profile-avatar">{{profileInitial}}</view><view class="profile-meta"><view class="profile-name">{{activeBookName}}</view><view class="profile-desc">{{goalText}}</view></view></view>
    <view class="profile-divider"></view>
    <view class="profile-highlight"></view>
  </view>
  <view class="section-card"><view class="section-title">学习进度</view><block wx:for="{{progressStats}}" wx:key="key"><view class="profile-stat-row" bindtap="onStatTap" data-key="{{item.key}}"><view><view class="profile-stat-label">{{item.label}}</view><view class="profile-stat-note">{{item.note}}</view></view><view class="profile-stat-value">{{item.value}}</view></view></block></view>
  <view class="section-card"><view class="section-title">快捷入口</view><block wx:for="{{shortcuts}}" wx:key="id"><view class="profile-link-row" bindtap="onShortcutTap" data-id="{{item.id}}"><view><view class="profile-link-title">{{item.title}}</view><view class="profile-link-desc">{{item.desc}}</view></view><text class="profile-link-arrow">›</text></view></block></view>
  <view class="section-card"><view class="section-title">关于与帮助</view><block wx:for="{{supportItems}}" wx:key="id"><view class="profile-link-row" bindtap="onSupportTap" data-id="{{item.id}}"><view><view class="profile-link-title">{{item.title}}</view><view class="profile-link-desc">{{item.desc}}</view></view><text class="profile-link-arrow">›</text></view></block></view>
</view>
