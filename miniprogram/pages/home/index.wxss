@import "../../styles/tokens.wxss";

.page-home {
  position: relative;
  padding: 24rpx 24rpx 44rpx;
  overflow: hidden;
}

.home-bg {
  position: absolute;
  border-radius: 50%;
  filter: blur(10rpx);
  animation: drift 10s ease-in-out infinite;
}

.home-bg--one {
  width: 320rpx;
  height: 320rpx;
  top: -120rpx;
  right: -140rpx;
  background: radial-gradient(circle, rgba(156, 183, 181, 0.24) 0%, rgba(156, 183, 181, 0) 72%);
}

.home-bg--two {
  width: 260rpx;
  height: 260rpx;
  top: 560rpx;
  left: -100rpx;
  background: radial-gradient(circle, rgba(216, 171, 104, 0.18) 0%, rgba(216, 171, 104, 0) 70%);
  animation-duration: 12s;
}

.home-hero {
  position: relative;
  overflow: hidden;
  padding: 36rpx;
  border-radius: 36rpx;
  background:
    linear-gradient(160deg, rgba(255, 253, 248, 0.14) 0%, rgba(255, 253, 248, 0) 42%),
    linear-gradient(145deg, #314844 0%, #496e67 54%, #6f938b 100%);
  color: #fffdf8;
  box-shadow: var(--shadow-hero);
}

.home-hero__shine {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.home-hero__shine::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 140rpx;
  height: 100%;
  background: linear-gradient(90deg, rgba(255, 253, 248, 0) 0%, rgba(255, 253, 248, 0.14) 50%, rgba(255, 253, 248, 0) 100%);
  transform: translateX(-140%);
  animation: shimmer 5.4s ease-in-out infinite;
}

.home-hero__top,
.hero-meta,
.section-head,
.weak-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.home-hero__top {
  position: relative;
  z-index: 1;
}

.home-hero__content {
  flex: 1;
  min-width: 0;
}

.hero-chip,
.section-tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.hero-chip {
  background: rgba(255, 253, 248, 0.14);
  color: rgba(255, 253, 248, 0.94);
}

.hero-title {
  margin-top: 18rpx;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.24;
}

.hero-subtitle {
  margin-top: 14rpx;
  max-width: 490rpx;
  font-size: 24rpx;
  line-height: 1.82;
  color: rgba(255, 253, 248, 0.82);
}

.hero-aside {
  min-width: 170rpx;
  padding: 22rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 253, 248, 0.11);
  box-shadow: inset 0 0 0 1rpx rgba(255, 253, 248, 0.08);
  text-align: right;
}

.hero-aside__label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 253, 248, 0.74);
}

.hero-aside__value {
  display: block;
  margin-top: 10rpx;
  font-size: 52rpx;
  font-weight: 700;
}

.hero-progress-wrap {
  position: relative;
  z-index: 1;
  margin-top: 30rpx;
}

.hero-progress {
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 253, 248, 0.13);
  overflow: hidden;
}

.hero-progress__bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #d8ab68 0%, #fff7df 100%);
}

.hero-progress__text {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: rgba(255, 253, 248, 0.82);
}

.hero-meta {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
}

.hero-meta__item {
  flex: 1;
  padding: 18rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 253, 248, 0.10);
  box-shadow: inset 0 0 0 1rpx rgba(255, 253, 248, 0.08);
}

.hero-meta__label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 253, 248, 0.72);
}

.hero-meta__value {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.hero-cta-row {
  position: relative;
  z-index: 1;
  margin-top: 30rpx;
}

.hero-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 86rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #fff6e5 0%, #f5e8cf 100%);
  color: #2f4b45;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  box-shadow: 0 16rpx 34rpx rgba(27, 43, 39, 0.14);
}

.hero-cta-note {
  margin-top: 14rpx;
  text-align: center;
  color: rgba(255, 253, 248, 0.76);
  font-size: 22rpx;
  line-height: 1.6;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.metric-card,
.section-card {
  border-radius: 30rpx;
  background: var(--surface);
  box-shadow: var(--shadow-card);
}

.metric-card {
  position: relative;
  overflow: hidden;
  padding: 24rpx;
}

.metric-card::after {
  content: "";
  position: absolute;
  inset: auto -40rpx -64rpx auto;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(156, 183, 181, 0.16) 0%, rgba(156, 183, 181, 0) 70%);
}

.metric-card--primary {
  background: linear-gradient(180deg, #f5f7f1 0%, #fffdf8 100%);
}

.metric-label,
.metric-helper,
.section-desc,
.trend-label,
.trend-value,
.action-desc,
.weak-translation,
.empty-tip {
  color: var(--ink-soft);
}

.metric-label {
  font-size: 22rpx;
}

.metric-value {
  display: block;
  margin: 12rpx 0 8rpx;
  color: var(--ink-strong);
  font-size: 42rpx;
  font-weight: 700;
}

.metric-helper {
  font-size: 22rpx;
  line-height: 1.6;
}

.section-card {
  margin-top: 24rpx;
  padding: 26rpx;
}

.section-head {
  align-items: flex-start;
}

.section-title,
.action-title,
.weak-word {
  color: var(--ink-strong);
  font-size: 30rpx;
  font-weight: 700;
}

.section-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
}

.section-tag {
  background: var(--brand-soft);
  color: var(--brand);
}

.section-link {
  color: var(--brand);
  font-size: 24rpx;
  font-weight: 600;
}

.trend-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 10rpx;
  margin-top: 24rpx;
}

.trend-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
}

.trend-bar-wrap {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  width: 100%;
  height: 136rpx;
}

.trend-bar {
  width: 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #b1c6c1 0%, #4f7a6c 100%);
  box-shadow: 0 10rpx 22rpx rgba(79, 122, 108, 0.16);
  animation: float-slow 4.4s ease-in-out infinite;
}

.trend-value {
  margin-top: 10rpx;
  font-size: 20rpx;
}

.trend-label {
  margin-top: 6rpx;
  font-size: 20rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 22rpx;
}

.action-card {
  position: relative;
  min-height: 206rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #f9f6ef 0%, #f1ede4 100%);
  overflow: hidden;
}

.action-card::after {
  content: "";
  position: absolute;
  right: -20rpx;
  bottom: -20rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(216, 171, 104, 0.16) 0%, rgba(216, 171, 104, 0) 72%);
}

.action-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: linear-gradient(145deg, #4f7a6c 0%, #88a69e 100%);
  color: #fffdf8;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 14rpx 28rpx rgba(79, 122, 108, 0.16);
}

.action-title {
  margin-top: 20rpx;
}

.action-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
}

.action-link {
  display: inline-block;
  margin-top: 18rpx;
  color: var(--brand);
  font-size: 22rpx;
  font-weight: 600;
}

.weak-row {
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--line);
}

.weak-row:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.weak-main {
  flex: 1;
  min-width: 0;
}

.weak-translation {
  margin-top: 10rpx;
  font-size: 24rpx;
}

.weak-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--brand-soft);
  color: var(--brand);
  font-size: 22rpx;
}

.pill-danger {
  background: rgba(201, 106, 87, 0.12);
  color: var(--danger);
}

.weak-arrow {
  color: var(--brand);
  font-size: 26rpx;
  font-weight: 600;
}

.empty-tip {
  padding-top: 24rpx;
  font-size: 24rpx;
  line-height: 1.7;
}
