@import "../../styles/tokens.wxss";
.page-home { padding: 24rpx 24rpx 40rpx; }
.hero-card { background: linear-gradient(135deg, #4f46e5 0%, #2563eb 58%, #0f172a 100%); border-radius: 36rpx; padding: 32rpx; color: #fff; box-shadow: var(--shadow-hero); position: relative; overflow: hidden; }
.hero-card::after { content: ''; position: absolute; width: 260rpx; height: 260rpx; right: -60rpx; top: -80rpx; border-radius: 50%; background: rgba(255,255,255,0.08); }
.hero-top { display: flex; justify-content: space-between; gap: 24rpx; position: relative; z-index: 1; }
.badge { display: inline-flex; align-items: center; padding: 10rpx 18rpx; border-radius: 999rpx; background: rgba(255,255,255,0.15); font-size: 22rpx; }
.hero-title { margin-top: 20rpx; font-size: 46rpx; font-weight: 700; line-height: 1.28; }
.hero-subtitle { margin-top: 14rpx; font-size: 24rpx; line-height: 1.75; color: rgba(255,255,255,0.88); max-width: 470rpx; }
.hero-stat { min-width: 150rpx; padding: 20rpx; border-radius: 24rpx; background: rgba(15,23,42,0.22); text-align: right; }
.hero-stat-label { display: block; font-size: 22rpx; color: rgba(255,255,255,0.72); }
.hero-stat-value { display: block; margin-top: 8rpx; font-size: 56rpx; font-weight: 700; }
.hero-progress { margin-top: 26rpx; height: 14rpx; border-radius: 999rpx; background: rgba(255,255,255,0.16); overflow: hidden; position: relative; z-index: 1; }
.hero-progress-bar { height: 100%; border-radius: 999rpx; background: linear-gradient(90deg, #fde68a 0%, #ffffff 100%); }
.hero-progress-text { margin-top: 10rpx; position: relative; z-index: 1; font-size: 22rpx; color: rgba(255,255,255,0.8); }
.hero-footer { display: flex; justify-content: space-between; gap: 16rpx; margin-top: 20rpx; position: relative; z-index: 1; }
.hero-footer-item { flex: 1; padding: 18rpx 20rpx; border-radius: 22rpx; background: rgba(255,255,255,0.12); }
.hero-footer-label { display: block; font-size: 22rpx; color: rgba(255,255,255,0.72); }
.hero-footer-value { display: block; margin-top: 8rpx; font-size: 30rpx; font-weight: 600; }
.primary-button { margin-top: 28rpx; border-radius: 999rpx; background: #fff; color: var(--brand-strong); font-size: 30rpx; font-weight: 700; box-shadow: 0 14rpx 28rpx rgba(255,255,255,0.18); }
.primary-button::after { border: none; }
.metrics-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18rpx; margin-top: 24rpx; }
.metric-card,.section-card { background: var(--surface); border-radius: 28rpx; padding: 24rpx; box-shadow: var(--shadow-card); }
.metric-label,.section-desc,.action-desc,.word-desc,.empty-tip { color: var(--text-secondary); font-size: 22rpx; line-height: 1.6; }
.metric-value { display: block; margin: 14rpx 0 10rpx; color: var(--text-primary); font-size: 42rpx; font-weight: 700; }
.metric-helper { color: #94a3b8; font-size: 20rpx; }
.metric-card--accent { background: linear-gradient(180deg, #eef2ff 0%, #fff 100%); }
.section-card { margin-top: 24rpx; }
.section-header,.action-row,.word-row { display: flex; justify-content: space-between; align-items: center; gap: 18rpx; }
.section-title,.action-title,.word-title { color: var(--text-primary); font-size: 30rpx; font-weight: 700; }
.section-link,.action-arrow { color: var(--brand); font-size: 24rpx; }
.action-row,.word-row { padding: 24rpx 0; border-bottom: 1rpx solid var(--border-color); }
.action-row:last-child,.word-row:last-child { border-bottom: none; padding-bottom: 0; }
.action-row:first-of-type,.word-row:first-of-type { padding-top: 18rpx; }
.action-title-wrap,.word-main { flex: 1; min-width: 0; }
.action-icon { width: 64rpx; height: 64rpx; border-radius: 18rpx; background: var(--brand-soft); color: var(--brand); display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 700; flex-shrink: 0; }
.word-meta { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 10rpx; }
.pill { padding: 10rpx 18rpx; border-radius: 999rpx; background: #eef2ff; color: var(--brand); font-size: 22rpx; }
.pill-danger { background: #fef2f2; color: var(--danger); }
.empty-tip { padding-top: 22rpx; }
.trend-chart { display: flex; align-items: flex-end; justify-content: space-between; gap: 10rpx; margin-top: 24rpx; }
.trend-item { display: flex; flex-direction: column; align-items: center; flex: 1; }
.trend-bar-wrap { width: 100%; height: 120rpx; display: flex; align-items: flex-end; justify-content: center; }
.trend-bar { width: 24rpx; border-radius: 999rpx; background: linear-gradient(180deg, #818cf8 0%, #4f46e5 100%); }
.trend-value { margin-top: 10rpx; font-size: 20rpx; color: var(--text-primary); }
.trend-label { margin-top: 6rpx; font-size: 20rpx; color: var(--text-secondary); }
