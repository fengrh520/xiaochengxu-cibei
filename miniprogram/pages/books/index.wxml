<view class="page">
  <view class="section-card feature-card" wx:if="{{currentBook}}"><view class="section-title">当前词书</view><view class="book-title">{{currentBook.name}}</view><view class="book-desc">{{currentBook.description}}</view><view class="book-metrics"><view class="metric-box"><text class="metric-value">{{bookMetrics.total}}</text><text class="metric-label">总词数</text></view><view class="metric-box"><text class="metric-value">{{bookMetrics.studied}}</text><text class="metric-label">已学习</text></view><view class="metric-box"><text class="metric-value">{{bookMetrics.mastered}}</text><text class="metric-label">已掌握</text></view><view class="metric-box"><text class="metric-value">{{bookMetrics.due}}</text><text class="metric-label">待复习</text></view></view></view>
  <view class="section-card"><view class="section-title">切换词书</view><block wx:for="{{allBooks}}" wx:key="id"><view class="list-row {{currentBook && currentBook.id === item.id ? 'list-row--active' : ''}}" bindtap="onSelectBook" data-id="{{item.id}}"><view><view class="list-title">{{item.name}}</view><view class="muted">{{item.exam}} · {{item.description}}</view></view><text class="list-link">{{currentBook && currentBook.id === item.id ? '当前使用' : '切换'}}</text></view></block></view>
  <view class="section-card"><view class="section-title">导入与备份</view><view class="muted">当前版本先聚焦核心学习闭环；文件导入、备份恢复会在后续版本继续补齐。</view><button class="secondary-button" bindtap="onFeatureTap">查看规划说明</button></view>
</view>
